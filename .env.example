# Copy this file to .env.local and fill in real values.
# Use Stripe TEST mode keys until explicitly told to switch to live.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Email (Resend) for quote emails at checkout
RESEND_API_KEY=
QUOTE_FROM_EMAIL=
QUOTE_NOTIFY_EMAIL=

# Google Calendar — staff consultation appointments (server-only).
# GOOGLE_REFRESH_TOKEN is obtained once via /api/auth/google-calendar
# (sign in with the business Gmail, copy the token from the server logs).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALENDAR_ID=
GOOGLE_REFRESH_TOKEN=
# Optional: force the OAuth redirect URI (must exactly match a URI registered in
# Google Cloud Console). If unset, it's derived from the request host. Set this
# on Vercel if the derived value ever differs from your registered URI, e.g.:
# GOOGLE_OAUTH_REDIRECT_URI=https://the-closet-fitters.vercel.app/api/auth/google-calendar/callback
GOOGLE_OAUTH_REDIRECT_URI=
